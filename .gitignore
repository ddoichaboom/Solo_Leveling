# =========================
# Visual Studio
# =========================

# VS 작업 캐시
.vs/

# 사용자 설정 파일
*.vcxproj.user
*.suo
*.user
*.userosscache
*.sln.docstates

# IntelliSense / DB
*.VC.db
*.VC.opendb
Browse.VC.db*
*.pdb

# IPCH (Precompiled Header Cache)
ipch/
*.ipch

# 빌드 결과물
Debug/
Release/
x64/
x86/
out/
build/

# CMake
CMakeFiles/
CMakeCache.txt

# 로그
*.log

# 임시 파일
*.tmp
*.tlog

# 자동 생성 인덱스
FileContentIndex/

# Windows
Thumbs.db
.DS_Store

# =========================
# 빌드 산출물 (Bin 폴더)
# =========================
*/Bin/
ClientSDK/Lib/
EngineSDK/Lib/

# =========================
# 컴파일된 셰이더
# =========================
*.cso

# =========================
# SDK 배포 (bat으로 자동 생성)
# =========================
EngineSDK/Inc/
ClientSDK/Inc/

# =========================
# 서드파티 라이브러리 (바이너리)
# =========================
Engine/ThirdPartyLib/
Editor/ThirdPartyLib/

# =========================
# ImGui 설정 (사용자별 레이아웃)
# =========================
**/imgui.ini

# =========================
# Resources (대용량 에셋)
# =========================
Resources/*
!Resources/ShaderFiles/
